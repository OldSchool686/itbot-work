# MAX Messenger Bot
MAX_BOT_TOKEN=ТокенМаксБота
MAX_WEBHOOK_URL=изличногокабинетаMAX или свой webhook
MAX_POLLING=false

# Bitrix24 Integration
BITRIX24_WEBHOOK_URL=
BITRIX24_DEAL_TYPE_ID=SERVICE
BITRIX24_STAGE_NEW=NEW
BITRIX24_STAGE_IN_PROGRESS=IN_PROGRESS
BITRIX24_STAGE_RESOLVED=RESOLVED
BITRIX24_STAGE_CLOSED=CLOSED
BITRIX24_AUTO_CLOSE_DAYS=14

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_CHAT=ИмяМодельLLM
OLLAMA_MODEL_EMBED=nomic-embed-text

# PostgreSQL
POSTGRES_DB=ИмяБД
POSTGRES_USER=ИмяЮзерБД
POSTGRES_PASSWORD=ПАРОЛЬЮЗЕРБД
DATABASE_URL=postgresql://ИмяЮзерБД:ПАРОЛЬЮЗЕРБД@postgres:5432/ИмяБД

# Redis
REDIS_URL=redis://redis:6379/0

# ChromaDB
CHROMA_DB_HOST=chromadb
CHROMA_DB_PORT=8000

# Admin Panel Authentication (для дашборда)
ADMIN_SESSION_SECRET=
ADMIN_TOKEN_EXPIRE_MINUTES=30
# учетка админа
ADMIN_INITIAL_USERNAME=логин
ADMIN_INITIAL_PASSWORD=пароль

# Initial Allowed User (whitelist seed — bot admin)
ADMIN_INITIAL_PHONE=+7
ADMIN_INITIAL_FULL_NAME="ФИО"

# Application LOG_LEVEL=WARNING or INFO
APP_BASE_URL=https://свойадрессайта.ru  #REQUIRED — base URL for download links, webhooks, etc.
APP_ENV=production
LOG_LEVEL=WARNING
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3
AI_CACHE_TTL=3600

# User Whitelist
WHITELIST_ENABLED=true
WHITELIST_STRICT_MODE=true
WHITELIST_PHONE_FORMATS=+7XXXXXXXXXX,8XXXXXXXXXX,+XXXXXXXXXXX

# Internal API protection (shared secret between bot and backend)
INTERNAL_API_KEY=

# CORS
ALLOWED_CORS_ORIGINS=http://localhost:8000,https://свойадрессайта.ru